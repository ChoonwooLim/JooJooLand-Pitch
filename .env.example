# ==========================================================
# JooJooLand — 환경변수 템플릿
# 실제 값은 .env (git 미추적) 또는 Orbitron secrets 에서 주입
# ==========================================================

# ── Database (Orbitron PostgreSQL) ──
DATABASE_URL=postgresql://orbitron_user:orbitron_db_pass@orbitron-joojooland-db:3183/orbitron_db
# 로컬 개발용 SQLite fallback (DATABASE_URL 미설정 시)
# DATABASE_URL=sqlite:///./joojooland.db

# ── JWT / 쿠키 ──
JWT_SECRET=change-me-in-production-random-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# ── OpenClaw (LAN, CLI plan-token 전용) ──
# 주의: ANTHROPIC_API_KEY / OPENAI_API_KEY 는 절대 등록 금지
OPENCLAW_WS_URL=ws://192.168.219.117:18789
OPENCLAW_AGENT_PET=joojoo-pet-agent
OPENCLAW_MODEL_DEFAULT=anthropic/claude-opus-4-7
OPENCLAW_MODEL_AGENT=openai-codex/gpt-5.4
OPENCLAW_MODEL_VISION=anthropic/claude-sonnet-4-6

# ── UE5 Pixel Streaming (Wilbur) ──
UE5_SIGNALING_URL=ws://192.168.219.117:8888
UE5_PIXEL_STREAMER_URL=http://192.168.219.117:8080

# ── 이미지 생성 (LAN Flux) ──
AI_IMAGE_SERVICE_URL=http://192.168.219.117:8100

# ── 지도 (VWorld / Cesium) ──
VWORLD_API_KEY=
CESIUM_ION_TOKEN=

# ── 이메일 (Resend) ──
# 비어있으면 email_log 테이블에 기록만 됨 (실제 전송 안 함)
RESEND_API_KEY=
EMAIL_FROM=noreply@joojooland.twinverse.org
EMAIL_FROM_NAME=JooJooLand
PASSWORD_RESET_TTL_MIN=30

# ── Superadmin seed ──
ADMIN_EMAIL=choonwoo49@gmail.com
ADMIN_PASSWORD=changeme-on-first-boot

# ── Frontend URL (CORS + 이메일 링크) ──
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Uploads ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=200
