# ==========================================================
# JooJooLand — 환경변수 템플릿
# 실제 값은 .env (git 미추적) 또는 Orbitron secrets 에서 주입
# ==========================================================

# ── Database (Orbitron PostgreSQL) ──
DATABASE_URL=postgresql://orbitron_user:orbitron_db_pass@orbitron-joojooland-db:3183/orbitron_db
# 로컬 개발용 SQLite fallback (DATABASE_URL 미설정 시)
# DATABASE_URL=sqlite:///./joojooland.db

# ── JWT ──
JWT_SECRET_KEY=change-me-in-production-random-64-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── OpenClaw (LAN, CLI plan-token 전용) ──
# 주의: ANTHROPIC_API_KEY / OPENAI_API_KEY 는 절대 등록 금지
OPENCLAW_WS_URL=ws://192.168.219.117:18789
OPENCLAW_TOKEN=
OPENCLAW_AGENT_PET=joojoo-pet-agent
OPENCLAW_MODEL_DEFAULT=anthropic/claude-opus-4-7
OPENCLAW_MODEL_AGENT=openai-codex/gpt-5.4
OPENCLAW_MODEL_VISION=anthropic/claude-sonnet-4-6

# ── UE5 Pixel Streaming (Wilbur) ──
WILBUR_URL=
WILBUR_PLAYER_PORT=8080
WILBUR_SFU_PORT=8888

# ── 이미지 생성 (LAN Flux) ──
AI_IMAGE_SERVICE_URL=http://192.168.219.117:8100

# ── Admin seed ──
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=change-me-in-production

# ── Frontend URL (CORS) ──
FRONTEND_URL=http://localhost:5173

# ── Uploads ──
UPLOAD_DIR=./uploads
