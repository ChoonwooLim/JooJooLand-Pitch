{
  "name": "joojooland-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k -n BACK,FRONT -c blue.bold,green.bold \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "cd ../backend && python -m uvicorn app.main:app --reload --port 8000 --host 0.0.0.0",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "axios": "^1.14.0",
    "framer-motion": "^11.11.0",
    "i18next": "^24.0.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.1.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/leaflet": "^1.9.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  },
  "comments": {
    "note": "resium/cesium 은 번들 사이즈 문제로 Map 3D 페이지에서 동적 import. 최초 로드시 설치 불필요하게 peer 로만 요구."
  },
  "optionalDependencies": {
    "cesium": "^1.122.0",
    "resium": "^1.18.0"
  }
}
