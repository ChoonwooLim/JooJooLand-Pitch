APP_NAME="JooJooLand Pitch API"
ENV=development

# Orbitron 배포 시 실제 DSN 주입 (로컬은 SQLite fallback)
DATABASE_URL=sqlite:///./joojooland.db
# 운영: postgresql://orbitron_user:orbitron_db_pass@orbitron-joojooland-db:3183/orbitron_db

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=1440

ADMIN_EMAIL=choonwoo49@gmail.com
ADMIN_PASSWORD=changeme-on-first-boot

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# === AI: OpenClaw LAN Gateway 전용 (API 키 금지) ===
OPENCLAW_WS_URL=ws://192.168.219.117:18789
OPENCLAW_AGENT_PET=joojoo-pet-agent
OPENCLAW_MODEL_DEFAULT=anthropic/claude-opus-4-7
OPENCLAW_MODEL_AGENT=openai-codex/gpt-5.4
OPENCLAW_MODEL_VISION=anthropic/claude-sonnet-4-6
# 주의: ANTHROPIC_API_KEY / OPENAI_API_KEY 는 절대 등록 금지

# === UE5 Pixel Streaming 2 ===
UE5_SIGNALING_URL=ws://192.168.219.117:8888
UE5_PIXEL_STREAMER_URL=http://192.168.219.117:8080

# === VWorld 오픈API (국토교통부 지적도) ===
# https://www.vworld.kr/dev/v4api.do 에서 무료 발급 (서비스 URL: https://joojooland.twinverse.org)
VWORLD_API_KEY=
# VWorld 콘솔에 등록한 서비스 URL 의 호스트명 (프로토콜·경로 제외).
# 백엔드 프록시가 domain 파라미터를 이 값으로 덮어써서 localhost 등 미등록 도메인에서도
# INCORRECT_KEY 에러 없이 호출된다. 비우면 브라우저가 보낸 값 그대로 전달.
VWORLD_REGISTERED_DOMAIN=joojooland.twinverse.org

# === 산림청 SHP 자체 적재 (docs/forest-shp-ingest.md) ===
# 전국 SHP 원본 디렉토리. imsang.shp / sanji.shp / landslide.shp 등 파일이 풀려 있어야 함.
FOREST_SHP_DIR=
# 프로젝트 BBOX (lngMin,latMin,lngMax,latMax, EPSG:4326). 프로젝트마다 다르게.
PROJECT_BBOX=127.50,37.30,127.85,37.60
PROJECT_NAME=JooJooLand

# === Cesium Ion (3D 지형·위성 타일) ===
# https://ion.cesium.com/tokens 에서 무료 발급 (월 50k 타일)
CESIUM_ION_TOKEN=
